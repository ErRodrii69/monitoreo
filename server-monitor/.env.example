# =============================================================
# .env.example — Variables de entorno del proyecto
# Copia este fichero como ".env" y rellena los valores reales.
# NUNCA subas el .env real al repositorio.
# =============================================================

# --- PostgreSQL ---
POSTGRES_USER=monitor
POSTGRES_PASSWORD=cambia_esto_en_produccion
POSTGRES_DB=servermonitor
POSTGRES_PORT=5432           # Puerto expuesto en el host

# --- Backend ---
BACKEND_PORT=8000

# --- Monitorización ---
CHECK_INTERVAL_SECONDS=60    # Intervalo entre rondas de ping (mín. 10)
PING_TIMEOUT_SECONDS=3       # Tiempo máx. de espera por ping
PING_COUNT=1                 # Paquetes ICMP por comprobación

# --- Notificaciones por correo (Gmail de ejemplo) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_cuenta@gmail.com
SMTP_PASSWORD=tu_app_password_de_gmail
SMTP_FROM=tu_cuenta@gmail.com
ALERT_EMAIL_TO=admin@tuempresa.com
